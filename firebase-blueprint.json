{
  "entities": {
    "AnalysisReport": {
      "title": "Analysis Report",
      "description": "A summary of a Kavach diagnostic analysis.",
      "type": "object",
      "properties": {
        "locoId": { "type": "string", "description": "The locomotive ID analyzed." },
        "date": { "type": "string", "format": "date-time", "description": "The date and time of the analysis." },
        "overallPerformance": { "type": "number", "description": "The overall RFCOMM success percentage." },
        "nmsFailRate": { "type": "number", "description": "The NMS failure rate percentage." },
        "avgLag": { "type": "number", "description": "The average radio MA lag in seconds." },
        "badStations": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of station IDs with performance below 95%."
        },
        "userId": { "type": "string", "description": "The UID of the user who performed the analysis." },
        "notes": { "type": "string", "description": "Manual technician notes." },
        "status": { "type": "string", "enum": ["Pending", "Resolved"], "description": "Current maintenance status." },
        "isFlagged": { "type": "boolean", "description": "Whether this loco is on the watchlist." }
      },
      "required": ["locoId", "date", "overallPerformance", "userId"]
    },
    "StationHistory": {
      "title": "Station History",
      "description": "Historical performance data for a specific station.",
      "type": "object",
      "properties": {
        "stationId": { "type": "string", "description": "The station ID." },
        "date": { "type": "string", "format": "date-time", "description": "The date of the analysis." },
        "locoId": { "type": "string", "description": "The loco ID that reported the performance." },
        "percentage": { "type": "number", "description": "The RFCOMM success percentage." },
        "received": { "type": "number", "description": "Number of packets received." },
        "expected": { "type": "number", "description": "Number of packets expected." },
        "userId": { "type": "string", "description": "The UID of the user." }
      },
      "required": ["stationId", "date", "locoId", "percentage", "userId"]
    }
  },
  "firestore": {
    "/reports/{reportId}": {
      "schema": "AnalysisReport",
      "description": "Collection of analysis reports."
    },
    "/station_history/{historyId}": {
      "schema": "StationHistory",
      "description": "Historical performance logs for stations."
    }
  }
}
